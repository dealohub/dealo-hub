# =============================================================================
# Dealo Hub — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git (it's in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Task #7)
# -----------------------------------------------------------------------------
# Region: ap-south-1 (Mumbai) — per GCC-READINESS.md
# Find these at: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — SERVER ONLY. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Direct database URL (for migrations + seeds)
SUPABASE_DB_URL=postgresql://postgres:[YOUR_PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# OpenAI (Task #8)
# -----------------------------------------------------------------------------
# Get key from: https://platform.openai.com/api-keys
# Set usage limit: https://platform.openai.com/account/limits — $50/mo cap

OPENAI_API_KEY=sk-proj-...

# Model overrides (defaults match DECISIONS.md Decision 7)
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_MODEL_CRITICAL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Google Cloud Vision (Task #8)
# -----------------------------------------------------------------------------
# Used for reverse image search in fraud detection
# Budget alert: $30/mo

# JSON credentials file path (local dev)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-vision-credentials.json

# OR base64-encoded credentials (Vercel deployment)
# GCP_VISION_CREDENTIALS_BASE64=eyJ0eXBl...

GCP_PROJECT_ID=dealo-hub

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------

# PostHog (Week 1 setup)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Sentry (Week 2+)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# -----------------------------------------------------------------------------
# Email (Resend — Week 2+)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@dealohub.com

# -----------------------------------------------------------------------------
# SMS OTP — Twilio (Sprint 1 BRIEF-001 Auth)
# -----------------------------------------------------------------------------
# Configured inside Supabase Dashboard → Authentication → Providers → Phone (Twilio).
# Supabase sends the SMS for us once these are saved there; the vars below are
# only needed if we call Twilio directly (e.g. for server-side verification or
# custom templates). Keep for reference; not read by the auth flow by default.
#
# Get from https://console.twilio.com
# Dev: leave blank — Supabase test OTPs are used when no real Twilio is wired.
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxx

# Optional: Twilio Verify service SID (if using Verify instead of Messaging)
# TWILIO_VERIFY_SERVICE_SID=VAxxxxx

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------

# Base URL (used for canonical links + server actions)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default country for unknown users (Kuwait)
NEXT_PUBLIC_DEFAULT_COUNTRY=KW
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Feature flags (defaults per AI-FEATURES.md V1 scope)
NEXT_PUBLIC_FEATURE_AI_FRAUD=true
NEXT_PUBLIC_FEATURE_AI_SEMANTIC_SEARCH=true
NEXT_PUBLIC_FEATURE_AI_PHOTO_TO_LISTING=false  # Enable after Week 11-12 accuracy gate

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# Figma Personal Access Token (optional — for design-to-code workflows)
FIGMA_ACCESS_TOKEN=
