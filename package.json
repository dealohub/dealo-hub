{
  "name": "dealo-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Premium C2C marketplace for the Gulf — AI-Protected, Human-Written Listings",
  "author": "Fawzi Al-Ibrahim <fawzi.al.ibrahim@gmail.com>",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "psql $SUPABASE_DB_URL -f supabase/seed/0001_countries.sql -f supabase/seed/0002_cities_kw.sql -f supabase/seed/categories.sql",
    "db:types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/vision": "4.3.2",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-dropdown-menu": "2.1.1",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-toast": "1.2.1",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.0",
    "class-variance-authority": "0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "libphonenumber-js": "1.11.7",
    "lucide-react": "^0.414.0",
    "next": "16.2.4",
    "next-intl": "4.9.1",
    "next-themes": "^0.4.6",
    "openai": "4.52.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-phone-number-input": "3.4.5",
    "tailwind-merge": "^2.6.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "8.4.39",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.5",
    "supabase": "1.187.10",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.5.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
