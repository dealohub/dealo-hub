{
  "name": "dealo-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Premium C2C marketplace for the Gulf — AI-Protected, Human-Written Listings",
  "author": "Fawzi Al-Ibrahim <fawzi.al.ibrahim@gmail.com>",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "psql $SUPABASE_DB_URL -f supabase/seed/0001_countries.sql -f supabase/seed/0002_cities_kw.sql -f supabase/seed/categories.sql",
    "db:types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "dependencies": {
    "@google-cloud/vision": "4.3.2",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-dropdown-menu": "2.1.1",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-toast": "1.2.1",
    "@supabase/ssr": "0.4.0",
    "@supabase/supabase-js": "2.45.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "libphonenumber-js": "1.11.7",
    "lucide-react": "0.414.0",
    "next": "14.2.5",
    "next-intl": "^3.26.5",
    "openai": "4.52.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-phone-number-input": "3.4.5",
    "tailwind-merge": "2.4.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.11",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.39",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.5",
    "supabase": "1.187.10",
    "tailwindcss": "3.4.6",
    "tailwindcss-logical": "3.0.1",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
